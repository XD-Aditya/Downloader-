{
  "version": 2,
  "builds": [
    { "src": "api/download.py", "use": "@vercel/python" },
    { "src": "api/services.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/download", "dest": "/api/download.py" },
    { "src": "/api/download/(.*)", "dest": "/api/download.py" },
    { "src": "/api/services", "dest": "/api/services.py" }
  ]
}
