{
  "version": 2,
  "builds": [
    {
      "src": "api/download.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/service.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/download/(.*)", "dest": "/api/download.py" },
    { "src": "/services", "dest": "/api/service.py" }
  ]
}
